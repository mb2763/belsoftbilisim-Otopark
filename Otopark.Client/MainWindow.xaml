<Window x:Class="Otopark.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Otopark.Client.Views"
        xmlns:vm="clr-namespace:Otopark.Core;assembly=Otopark.Core"
        Title="Kapalı Otopark Sistemi - Belsoft Teknoloji"
        Icon="pack://application:,,,/Assets/logo_left.png"
        Height="720"
        Width="1280"
        MinWidth="1024"
        MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Login -->
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>

        <!-- Dashboard -->
        <DataTemplate DataType="{x:Type vm:PersonnelDashboardViewModel}">
            <views:PersonnelDashboardView/>
        </DataTemplate>

    </Window.Resources>

    <ContentControl Content="{Binding CurrentView}"/>

</Window>
