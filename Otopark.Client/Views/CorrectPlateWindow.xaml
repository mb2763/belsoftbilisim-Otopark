<Window x:Class="Otopark.Client.Views.CorrectPlateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plaka Duzelt"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FB">

    <Border Margin="16" Background="White" CornerRadius="12" Padding="20"
            BorderBrush="#E6EAF2" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Plaka Duzelt" FontSize="16" FontWeight="Bold"
                       Foreground="#1B2B4A" HorizontalAlignment="Center" Margin="0,0,0,14"/>

            <TextBlock Text="Eski Plaka" Foreground="#6B7A99" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TxtOldPlate" Height="34" Padding="8,0"
                     VerticalContentAlignment="Center" IsReadOnly="True"
                     Background="#F0F3F9" BorderBrush="#DDE3EE"/>

            <TextBlock Text="Yeni Plaka" Foreground="#6B7A99" FontSize="12" Margin="0,12,0,4"/>
            <TextBox x:Name="TxtNewPlate" Height="34" Padding="8,0" FontSize="14"
                     VerticalContentAlignment="Center"
                     BorderBrush="#DDE3EE" CharacterCasing="Upper"
                     MaxLength="10"
                     PreviewTextInput="TxtNewPlate_PreviewTextInput"
                     KeyDown="TxtNewPlate_KeyDown"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="BtnCancel" Content="Iptal" Width="90" Height="34" Margin="0,0,8,0"
                        Background="#E0E0E0" Foreground="#333" BorderThickness="0"
                        Click="BtnCancel_Click"/>
                <Button x:Name="BtnSave" Content="Kaydet" Width="110" Height="34"
                        Background="#2E7D32" Foreground="White" FontWeight="Bold" BorderThickness="0"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
