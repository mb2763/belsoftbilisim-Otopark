<Window x:Class="Otopark.Client.Views.PlateImagePopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Otopark.Client.Converters"
        Title="Plaka Goruntu"
        Width="700" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="400" MinHeight="350"
        Background="#F5F7FB">

    <Window.Resources>
        <conv:PathToImageConverter x:Key="PathToImage"/>
    </Window.Resources>

    <Border Margin="14" Background="White" CornerRadius="12" Padding="16"
            BorderBrush="#E6EAF2" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{Binding TitleText}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#6B7A99" HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>

            <Border Grid.Row="1" Background="#1B2B4A" CornerRadius="8"
                    Padding="14,10" Margin="0,0,0,12">
                <TextBlock Text="{Binding Plate}"
                           FontSize="32" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </Border>

            <Border Grid.Row="2" Background="#F0F3F9" CornerRadius="8"
                    BorderBrush="#DDE3EE" BorderThickness="1">
                <Image Source="{Binding ImagePath, Converter={StaticResource PathToImage}, ConverterParameter=1200}"
                       Stretch="Uniform" Margin="6"/>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Kapat" Width="100" Height="34"
                        Background="#2B7CFF" Foreground="White"
                        FontWeight="Bold" BorderThickness="0"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
